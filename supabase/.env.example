# ─── SceneOne — Supabase Edge Function secrets (TEMPLATE) ─────────────────
# Copy this file to  supabase/.env  and fill in REAL values.
#   cp supabase/.env.example supabase/.env
# supabase/.env is gitignored — NEVER commit it.
#
# This file is NOT read by the running app. It's a convenience for pushing
# secrets to Supabase, where the deployed Edge Functions read them via
# Deno.env.get(...). The static frontend never uses it.
#
# Push these to the live project:
#   supabase secrets set --env-file ./supabase/.env --project-ref zzsjgaijrngxkaqakplm
#
# (List what's currently set with:  supabase secrets list --project-ref zzsjgaijrngxkaqakplm)

# ── Claude (already set in prod — here for completeness) ──
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Stripe ──  Use TEST keys first (sk_test_…). Switch to live only when verified.
# Secret key:  https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# Webhook signing secret: created when you add the webhook endpoint in Stripe (whsec_…)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Recurring Price IDs — Stripe Dashboard → Products → (your plan) → the price → "price_…"
STRIPE_WRITER_PRICE_ID=price_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_REPLACE_ME

# ── Where Stripe returns the user after checkout (always production) ──
SITE_URL=https://sceneone.net

# NOTE: Supabase automatically injects SUPABASE_URL, SUPABASE_ANON_KEY, and
# SUPABASE_SERVICE_ROLE_KEY into Edge Functions. Do NOT set those here.
